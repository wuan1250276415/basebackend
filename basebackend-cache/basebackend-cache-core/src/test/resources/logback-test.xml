<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 测试里大量失败/回退分支是预期行为，避免把控制台刷满 -->
    <logger name="com.basebackend.cache.service.RedisService" level="OFF"/>
    <logger name="com.basebackend.cache.serializer.SerializerFactory" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
