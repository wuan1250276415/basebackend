# Repository-safe local defaults.
# 如果需要连接共享/远程环境，请复制为 env/.env.local 后单独维护，不要提交到 Git。

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=basebackend_admin
MYSQL_USER=basebackend_admin
MYSQL_USERNAME=basebackend_admin
MYSQL_PASSWORD=basebackend123
MYSQL_PORT=3306
MYSQL_HOST_PORT=3306
MYSQL_HOST=mysql

# Redis Configuration
REDIS_PORT=6379
REDIS_HOST=redis
REDIS_PASSWORD=redis2025
REDIS_HOST_PORT=6379
REDIS_DATABASE=0

# Nacos Configuration
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_HOSTNAME=nacos
NACOS_PREFER_HOST_MODE=hostname
NACOS_DATA_VOLUME=nacos-data-dev
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789
NACOS_AUTH_IDENTITY_KEY=nacos
NACOS_AUTH_IDENTITY_VALUE=nacos
NACOS_NAMESPACE=public
NACOS_DISCOVERY_SERVER=nacos:8848
NACOS_CONFIG_SERVER=nacos:8848
NACOS_DISCOVERY_NAMESPACE=public
NACOS_CONFIG_NAMESPACE=public
NACOS_DISCOVERY_USERNAME=nacos
NACOS_DISCOVERY_PASSWORD=nacos
NACOS_CONFIG_USERNAME=nacos
NACOS_CONFIG_PASSWORD=nacos

# RocketMQ Configuration
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_VIP_PORT=10909
ROCKETMQ_CONSOLE_PORT=8180
ROCKETMQ_NAME_SERVER=rocketmq-namesrv:9876

# Gateway Configuration
GATEWAY_PORT=8080

# Service Configuration
VERSION=1.0.0-SNAPSHOT
JWT_SECRET=basebackend-demo-secret-key-for-jwt-token-generation-minimum-256-bits-required
