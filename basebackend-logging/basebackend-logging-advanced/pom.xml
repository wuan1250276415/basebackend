<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.basebackend</groupId>
        <artifactId>basebackend-logging</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>basebackend-logging-advanced</artifactId>
    <packaging>jar</packaging>

    <name>Base Backend Logging Advanced</name>
    <description>高级日志特性：日志成本控制、动态日志级别、数据脱敏、日志管道、热日志缓存、性能基准测试</description>

    <dependencies>
        <!-- Logging Core -->
        <dependency>
            <groupId>com.basebackend</groupId>
            <artifactId>basebackend-logging-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Cache (for HotLogCache) -->
        <dependency>
            <groupId>com.basebackend</groupId>
            <artifactId>basebackend-cache-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Spring Boot Actuator (optional, for DynamicLogLevelEndpoint/LogCostEndpoint) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Nacos Config (optional, for NacosLogLevelListener) -->
        <dependency>
            <groupId>com.alibaba.cloud</groupId>
            <artifactId>spring-cloud-starter-alibaba-nacos-config</artifactId>
            <version>2022.0.0.0</version>
            <optional>true</optional>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test Dependencies -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
